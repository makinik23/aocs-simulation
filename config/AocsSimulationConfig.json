{
  "schema": "AocsSimulationConfig/v1",
  "mission": {
    "name": "leo_orbit_environment_disturbed_rigid_body",
    "description": "CubeSat attitude dynamics with Kepler orbit, IGRF magnetic field, eclipse, RMM, gravity-gradient, and SRP disturbance torques"
  },
  "models": {
    "plant": "aocs_plant",
    "directory": "models"
  },
  "results": {
    "directory": "results",
    "file": "aocs_simulation_results.mat"
  },
  "simulation": {
    "start_time_s": 0.0,
    "stop_time_s": 200.0,
    "sample_time_s": 0.1,
    "solver": "ode45",
    "relative_tolerance": 1.0e-9,
    "absolute_tolerance": 1.0e-10
  },
  "epoch": {
    "utc": [2026, 1, 1, 0, 0, 0],
    "time_system": "UTC",
    "tdb_minus_utc_s": 69.184
  },
  "orbit": {
    "central_body": "Earth",
    "propagator": {
      "type": "kepler_unperturbed",
      "output_frame": "ICRF"
    },
    "initial_keplerian": {
      "semi_major_axis_m": 6871000.0,
      "eccentricity": 0.001,
      "inclination_rad": 1.710422666954443,
      "raan_rad": 0.0,
      "argument_of_periapsis_rad": 0.0,
      "true_anomaly_rad": 0.0
    }
  },
  "spacecraft": {
    "id": "cubesat_3u",
    "mass_properties": {
      "inertia_B_kg_m2": [
        [0.02, 0.0, 0.0],
        [0.0, 0.025, 0.0],
        [0.0, 0.0, 0.035]
      ]
    }
  },
  "initial_conditions": {
    "q_BI": [1.0, 0.0, 0.0, 0.0],
    "omega_BI_B_rad_s": [0.2, 0.1, 1.5]
  },
  "environment": {
    "external_torque_B_Nm": [0.0, 0.0, 0.0],
    "residual_magnetic_dipole_B_A_m2": [0.01, 0.0, 0.0],
    "disturbances": {
      "residual_magnetic_moment_enabled": true,
      "gravity_gradient_enabled": true
    },
    "sun": {
      "model": "planet_ephemeris",
      "ephemeris_model": "DE405",
      "solar_constant_W_m2": 1361.0,
      "use_ephemeris_date_range": true,
      "ephemeris_start_utc": [2020, 1, 1, 0, 0, 0],
      "ephemeris_end_utc": [2030, 1, 1, 0, 0, 0],
      "action": "Error"
    },
    "srp": {
      "enabled": true,
      "model": "flat_plate_constant_area",
      "area_ref_m2": 0.03,
      "coefficient_reflectivity": 1.3,
      "center_of_pressure_B_m": [0.0, 0.0, 0.05]
    },
    "eclipse": {
      "enabled": true,
      "model": "dual_cone",
      "time_source": "dialog",
      "central_body": "Earth",
      "include_earth": true,
      "include_moon": true,
      "output_shadow_region": true,
      "ephemeris_model": "DE405",
      "use_ephemeris_date_range": true,
      "ephemeris_start_utc": [2020, 1, 1, 0, 0, 0],
      "ephemeris_end_utc": [2030, 1, 1, 0, 0, 0],
      "action": "Error",
      "zero_crossing": false
    }
  },
  "numerics": {
    "quat_norm_epsilon": 1.0e-12,
    "max_allowed_energy_drift": 1.0e-8,
    "max_allowed_Hnorm_drift": 1.0e-8
  },
  "conventions": {
    "quaternion_order": "scalar-first: q = [q0 q1 q2 q3]'",
    "q_BI": "attitude quaternion mapping inertial frame I to body frame B",
    "C_BI": "direction cosine matrix mapping v_I to v_B",
    "omega_BI_B": "angular velocity of body B wrt inertial I, expressed in body frame B"
  }
}
