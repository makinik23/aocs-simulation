{
  "extends": "../AocsSimulationConfig.json",
  "mission": {
    "name": "leo_high_precision",
    "description": "CubeSat attitude dynamics with maximum-degree EGM2008 spherical-harmonics orbit propagation"
  },
  "results": {
    "file": "aocs_high_precision.mat"
  },
  "orbit": {
    "propagator": {
      "type": "numerical_high_precision",
